{
  "name": "lnk-brewing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true pnpm run build",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky install",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "pnpm dlx @svgr/cli -d components/Icon/svgr assets/svg --typescript --icon",
    "precommit": "pnpm lint && pnpm build",
    "postinstall": "prisma generate && prisma db push && prisma db seed",
    "db:generate": "prisma generate ",
    "db:seed": "prisma db seed",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^1.0.2",
    "@heroicons/react": "^2.0.18",
    "@hookform/resolvers": "^3.3.2",
    "@prisma/client": "^5.7.1",
    "@prisma/extension-accelerate": "^0.6.2",
    "@types/node": "20.5.9",
    "@types/react": "18.2.21",
    "@types/react-dom": "18.2.7",
    "autoprefixer": "10.4.15",
    "axios": "^1.5.0",
    "cheerio": "1.0.0-rc.12",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "eslint": "8.48.0",
    "eslint-config-next": "13.4.19",
    "next": "14.0.5-canary.13",
    "next-auth": "5.0.0-beta.4",
    "postcss": "8.4.29",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.47.0",
    "slugify": "^1.6.6",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "3.3.3",
    "typescript": "5.2.2",
    "vitest": "^0.34.6",
    "zod": "3.21.4",
    "zod-form-data": "^2.0.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^13.4.19",
    "@storybook/addon-essentials": "^7.6.0",
    "@storybook/addon-interactions": "^7.6.0",
    "@storybook/addon-links": "^7.6.0",
    "@storybook/addon-onboarding": "^1.0.8",
    "@storybook/blocks": "^7.6.0",
    "@storybook/nextjs": "^7.6.0",
    "@storybook/react": "^7.6.0",
    "@storybook/test": "^7.6.0",
    "@tailwindcss/forms": "^0.5.6",
    "cross-env": "^7.0.3",
    "eslint-plugin-storybook": "^0.6.15",
    "husky": "^8.0.0",
    "prisma": "^5.7.1",
    "storybook": "^7.6.0",
    "ts-node": "^10.9.1"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
